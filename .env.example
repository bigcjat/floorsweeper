# ==============================================================================
# XRPL NFT Floor Sweeper Bot Configuration
# ==============================================================================

# Your XRPL Account Seed (secret key starting with 's')
# WARNING: Keep this secret safe and never commit the actual .env file.
XRPL_SEED=sYOUR_SECRET_SEED_HERE

# XRPL JSON-RPC Node Endpoint
# Mainnet: https://xrplcluster.com or https://s1.ripple.com:51234
# Testnet: https://s.altnet.rippletest.net:51234
XRPL_NODE=https://s2.ripple.com:51234/

# xrpldata.com API Key (Optional, for higher rate limits when fetching listings)
XRP_API_KEY=

# Safety Mode (True = Log only, do NOT submit transactions; False = Live Trading)
DRY_RUN=True

# Polling Interval (in seconds)
POLL_INTERVAL=60

# Target ceiling price in XRP for buying NFTs (max buy price)
TARGET_BUY_FLOOR_XRP=4.5

# Target floor price in XRP for listing/selling NFTs (minimum sell price)
TARGET_SELL_FLOOR_XRP=5.0

# NFT Collection Properties (Dropchan is default)
TARGET_ISSUER=rDropCHANEgmG7FBz1nzPpG27BGzWjnCnn
TARGET_TAXON=0

# Supported brokers and their fee multipliers (JSON mapping of Broker Address -> Multiplier)
# Default includes XRP Cafe (rpx9JThQ2y37FaGeeJP7PXDUVEXY3PHZSC) with a 1.589% fee (1.01589)
BROKERS_CONFIG='{"rpx9JThQ2y37FaGeeJP7PXDUVEXY3PHZSC": 1.01589}'

# Safety limits & user preferences
MAX_ACTIVE_BUYS=4
BUY_OFFER_EXPIRATION_SEC=600
RELIST_MARKUP_DIVISOR=0.8
# Whether to automatically list/relist bought NFTs (True/False)
AUTO_RELIST=True

# Enable/Disable placing buy offers on the entire collection (True/False)
COLLECTION_BID_ENABLED=False
# Buy price in XRP for the collection-wide offers
COLLECTION_BID_XRP=2.0


# Comma-separated list of NFTokenIDs that should be prioritized for purchase first if listed
PRIORITY_BUY_IDS=

# Comma-separated list of NFTokenIDs that should never be auto-listed/relisted, and whose buy offers should never be auto-cancelled
HOLD_IDS=

# Transaction Fee Management (in drops, 1 XRP = 1,000,000 drops)
# BASE_FEE_DROPS: The baseline transaction fee (default: 12 drops)
# MAX_FEE_DROPS: The maximum transaction fee you are willing to pay during network fee escalation (default: 1200 drops)
BASE_FEE_DROPS=12
MAX_FEE_DROPS=1200

# ==============================================================================
# Operational Modes & Profit Collector Configuration
# ==============================================================================
# BOT_MODE: REINVEST (default, continuous buying) or COLLECT_PROFIT (holds fixed inventory limit and sweeps surplus)
BOT_MODE=REINVEST

# MAX_OWNED_LIMIT: Maximum collection NFTs to hold before pausing buy sweeps (only used in COLLECT_PROFIT mode)
MAX_OWNED_LIMIT=10000

# PROFIT_TARGET_WALLET: The cold/recipient wallet where surplus XRP profit will be automatically transferred
PROFIT_TARGET_WALLET=

# PROFIT_TRANSFER_METHOD: PAYMENT (standard Payment transaction) or CHECK (native XRPL CheckCreate transaction)
PROFIT_TRANSFER_METHOD=PAYMENT

# MIN_OPERATING_BUFFER_XRP: The minimum free XRP balance to retain in the hot wallet for reserves/fees/tickets
MIN_OPERATING_BUFFER_XRP=30.0

# PROFIT_SWEEP_MIN_TRIGGER_XRP: The minimum surplus XRP required to trigger a transfer (prevents spamming tiny transfers)
PROFIT_SWEEP_MIN_TRIGGER_XRP=5.0


